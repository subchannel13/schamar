<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Schamar.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Schamar.Views.SingleImageWindow"
        x:DataType="vm:SingleImageWindowViewModel"
        Title="SingleImageWindow"
        Background="Black"
        Focusable="True">
    <Image Source="{Binding CurrentImage}"></Image>
    <Window.KeyBindings>
        <KeyBinding Gesture="Delete" Command="{Binding Reject}"></KeyBinding>
    </Window.KeyBindings>
</Window>
